{
  "manifest_version": 3,
  "name": "GPT to Markdown",
  "version": "0.0.1",
  "author": "My Name",
  "description": "Add a Markdown export button to each assistant message.",
  "permissions": ["downloads", "storage", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://api.notion.com/*"
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "mdRenderer.js",
        "content.js"],
      "run_at": "document_end"
    }
  ]
}
